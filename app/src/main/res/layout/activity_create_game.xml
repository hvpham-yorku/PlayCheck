<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:padding="24dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/backBtnCreateGame"
        android:layout_width="105dp"
        android:layout_height="wrap_content"
        android:text="Back" />

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:text="Create Game"
        android:textSize="26sp"
        android:textStyle="bold" />

    <AutoCompleteTextView
        android:id="@+id/teamA"
        android:hint="Team A"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <AutoCompleteTextView
        android:id="@+id/teamB"
        android:hint="Team B"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/gameVenue"
        android:hint="Venue"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <EditText
        android:id="@+id/gameType"
        android:hint="Sport"
        android:textColor="@color/black"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:hint="Select Date:"/>

        <Button
            android:id="@+id/gameDateBtn"
            android:hint="Click to Select Date"
            android:textColor="@color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="?android:spinnerStyle"
            android:onClick="expandDatePicker"/>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/black"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="@color/black"
            android:hint="Select Time:"/>

        <Button
            android:id="@+id/gameTimeBtn"
            android:hint="Click to Select Time"
            android:textColor="@color/black"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            style="?android:spinnerStyle"
            android:onClick="expandTimePicker"/>

    </LinearLayout>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Assign Referee (Optional)"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:textColor="@color/black" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <AutoCompleteTextView
            android:id="@+id/searchReferee"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Search referee by name..."
            android:drawableStart="@android:drawable/ic_menu_search" />

        <Button
            android:id="@+id/btnAddReferee"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/refereeRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="150dp"
        android:background="#F0F0F0"
        android:layout_marginTop="8dp" />


    <Button
        android:id="@+id/saveGame"
        android:text="Save Game"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="20dp"/>
</LinearLayout>