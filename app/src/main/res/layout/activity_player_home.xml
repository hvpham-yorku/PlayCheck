<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:paddingTop="16dp"
    android:background="#F5F5F5">
    <TextView
        android:id="@+id/playerTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Welcome Player"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Player Home"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="12dp"/>

    <Button
        android:id="@+id/btnPlayerViewGames"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="View Games"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnPlayerSchedule"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="View Schedule"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnPlayerTeams"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="My Teams"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btnMakeTeam"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:text="Create Team"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:text="Upcoming (preview)"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerPreview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
</LinearLayout>