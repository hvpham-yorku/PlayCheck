<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:id="@+id/singleTeam"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="8dp"
        app:cardBackgroundColor="#73c8dc"
        app:cardCornerRadius="12dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="top">

            <ImageView
                android:id="@+id/teamIcon"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_marginEnd="16dp"
                android:src="@drawable/outline_groups_24"
                app:tint="@color/black" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/myTeamName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Team Name"
                    android:textColor="@color/black"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/numberOfPlayers"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:text="Players: 12" />

                <TextView
                    android:id="@+id/clickShowDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Click to Show Team Details"
                    android:textColor="@color/black"
                    android:textSize="11sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:id="@+id/extraDetailsLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:layout_marginTop="10dp">

                    <TextView
                        android:id="@+id/captainText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Captain: Player Name"
                        android:textColor="@color/black"
                        android:textStyle="italic" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/winsText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Wins: 0"
                            android:textColor="@color/black"
                            android:layout_marginEnd="20dp" />

                        <TextView
                            android:id="@+id/lossesText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Losses: 0"
                            android:textColor="@color/black" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Players:"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_marginTop="12dp" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/innerRecyclerView"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>