<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtRefereeName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Referee Name"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#2C3E50" />

        <TextView
            android:id="@+id/txtRefereeEmail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="email@example.com"
            android:textSize="14sp"
            android:textColor="#7F8C8D" />

        <TextView
            android:id="@+id/txtRefereeStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Currently Assigned"
            android:textSize="12sp"
            android:textColor="#22C55E"
            android:visibility="gone" />

        <Button
            android:id="@+id/btnAssignReferee"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Assign"
            android:background="#7EADDB"
            android:textColor="#FFFFFF" />
    </LinearLayout>
</androidx.cardview.widget.CardView>
